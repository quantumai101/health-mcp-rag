# ── Health MCP RAG · Environment Variables ───────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# ── Required ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here        # free at console.groq.com

# ── Personalisation ───────────────────────────────────────────
OWNER_NAME=Your Name                        # shown in persona prompt

# ── Paths (defaults work for local dev) ──────────────────────
DATA_PATH=./data                            # folder with your documents
CHROMA_PATH=./chroma_db                    # vector index output

# ── Optional: Voice ───────────────────────────────────────────
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here

# ── Railway sets this automatically ──────────────────────────
# PORT=8000
